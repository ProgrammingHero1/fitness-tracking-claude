# This is a reference of every env var used across the monorepo.
# apps/api reads its own apps/api/.env ; apps/web reads its own apps/web/.env.local
# (both created once those apps are scaffolded — see execution-plan.md F3/F4).

# --- apps/api/.env ---
MONGODB_URI=                     # Atlas connection string, provided by you — never generate/commit a real value
MONGODB_DB_NAME=
PORT=4000                        # local dev only
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000
PLATFORM_ADMIN_EMAIL=                    # used once by scripts/seedPlatformAdmin.js
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_NAME=Platform Admin
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=
APP_BASE_URL=http://localhost:3000

# --- apps/web/.env.local ---
NEXT_PUBLIC_API_URL=             # unused/empty when proxying via rewrites
API_PROXY_TARGET=http://localhost:4000   # deployed apps/api Vercel URL in prod
